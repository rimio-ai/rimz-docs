{
  "name": "rimz-docs",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "next build",
    "check:output": "node scripts/check-static-output.mjs",
    "check:content": "node scripts/check-content.mjs",
    "dev": "next dev",
    "sync": "node scripts/sync-release.mjs",
    "start": "next start",
